{
  "name": "marketplace-platform-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Service Marketplace Platform — UI Foundation",
  "scripts": {
    "build": "npm run css:build",
    "dev": "npm run css:dev",
    "watch": "npm run css:watch",
    "css:build": "tailwindcss -i ui/css/main.css -o static/css/output.css --minify",
    "css:watch": "tailwindcss -i ui/css/main.css -o static/css/output.css --watch",
    "css:dev": "tailwindcss -i ui/css/main.css -o static/css/output.css"
  },
  "devDependencies": {
    "tailwindcss": "^3.4",
    "@tailwindcss/forms": "^0.5",
    "@tailwindcss/typography": "^0.5",
    "postcss": "^8.4",
    "autoprefixer": "^10.4"
  }
}
