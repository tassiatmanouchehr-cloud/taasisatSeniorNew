# Enterprise Service Marketplace Platform — Environment Variables
# Copy to .env and adjust values for your environment

# Django
# NOTE: manage.py defaults DJANGO_SETTINGS_MODULE to config.settings.development
# BEFORE this .env file is ever read, so this value has no effect on
# `python manage.py <command>` — it only matters for processes that read the
# OS environment directly (e.g. Celery workers). To run tests against
# config.settings.testing, set it explicitly for that command instead:
#   Windows (PowerShell): $env:DJANGO_SETTINGS_MODULE="config.settings.testing"; python manage.py test
#   Linux/Mac:             DJANGO_SETTINGS_MODULE=config.settings.testing python manage.py test
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=dev-only-insecure-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# GIS/PostGIS support
# Set to 'false' for native Windows/Mac development (no GDAL required)
# Set to 'true' for Docker/production (requires PostGIS + GDAL)
GIS_ENABLED=false

# Database (PostgreSQL)
# With GIS_ENABLED=false: uses django.db.backends.postgresql (no GDAL needed)
# With GIS_ENABLED=true: uses django.contrib.gis.db.backends.postgis
# Override explicitly with DATABASE_ENGINE if needed
# These values must match an ACTUAL role/database in your local PostgreSQL —
# installing PostgreSQL does not create them for you. If `migrate` fails with
# "password authentication failed for user marketplace", the role likely
# doesn't exist yet locally; see RUN_NATIVE_NO_VENV.md for the CREATE ROLE /
# CREATE DATABASE commands. Also check for a stale system-level
# DATABASE_PASSWORD environment variable (e.g. set via Windows `setx` in an
# earlier session) — it silently takes priority over this file, since
# .env values only fill in variables that aren't already set.
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=marketplace
DATABASE_USER=marketplace
DATABASE_PASSWORD=marketplace

# Test database name (used only when DJANGO_SETTINGS_MODULE=config.settings.testing)
DATABASE_TEST_NAME=test_marketplace

# Redis (optional for native dev — app falls back to LocMemCache if not set)
# REDIS_URL=redis://localhost:6379/0

# Celery (optional for native dev — tests use CELERY_TASK_ALWAYS_EAGER)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Locale
LANGUAGE_CODE=fa-ir
TIME_ZONE=Asia/Tehran

# Public site canonical tenant (optional — unset by default).
# Every apps.public_site page (homepage, caregiver/organization
# directories and detail pages, and their shared navigation) resolves
# its anonymous-visitor tenant context in this order: (1) an explicit
# ?tenant=<slug> query hint, always supported and always validated,
# (2) this setting, if set to a real tenant's slug, (3) the platform
# default tenant (TenantService), unchanged. Leave unset for the
# ordinary single-tenant deployment. Local development that walks
# through `python manage.py seed_product_walkthrough`'s dedicated demo
# tenant (rather than the platform default tenant) may set this to
# that tenant's own slug so the public site "just works" without
# requiring every link to be manually tagged with ?tenant=:
# PUBLIC_SITE_TENANT_SLUG=demo-senior-platform
