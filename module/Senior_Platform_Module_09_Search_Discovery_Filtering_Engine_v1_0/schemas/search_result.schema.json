{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SearchResult",
  "type": "object",
  "required": [
    "search_query_id",
    "results"
  ],
  "properties": {
    "search_query_id": {
      "type": "string"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "result_id",
          "result_type",
          "source_ref",
          "fields"
        ],
        "properties": {
          "result_id": {
            "type": "string"
          },
          "result_type": {
            "type": "string"
          },
          "source_ref": {
            "type": "object"
          },
          "fields": {
            "type": "object"
          },
          "explanation": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    },
    "facets": {
      "type": "array"
    },
    "next_cursor": {
      "type": [
        "string",
        "null"
      ]
    },
    "result_count_returned": {
      "type": "integer"
    },
    "result_count_total": {
      "type": [
        "integer",
        "null"
      ]
    }
  }
}
