{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SearchQuery",
  "type": "object",
  "required": [
    "tenant_id",
    "surface",
    "result_scope"
  ],
  "properties": {
    "tenant_id": {
      "type": "string"
    },
    "surface": {
      "type": "string"
    },
    "result_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "query_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "filters": {
      "type": [
        "object",
        "null"
      ]
    },
    "facets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sort": {
      "type": "string"
    },
    "page_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    },
    "cursor": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
